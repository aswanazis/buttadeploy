# ============================================
# FILE INI ADALAH CONTOH / TEMPLATE
# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke GitHub!
# ============================================

# Port server (Railway otomatis isi ini, tidak perlu diubah)
PORT=3000

# Environment: development atau production
NODE_ENV=production

# Session secret - buat string acak panjang minimal 32 karakter
# Contoh buat di terminal: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=ganti_dengan_string_acak_sangat_panjang_dan_rahasia

# Akun admin pertama (hanya dipakai saat database kosong/pertama kali)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti_dengan_password_kuat_kamu
